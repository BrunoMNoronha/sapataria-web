{
  "name": "sapataria-web",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo do Sistema Web da Sapataria",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel run dev",
    "dev:web": "pnpm --filter @sapataria/web dev",
    "dev:api": "pnpm --filter @sapataria/api dev",
    "build": "pnpm --recursive run build",
    "lint": "pnpm --recursive run lint",
    "test": "pnpm --recursive run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "prisma:validate": "pnpm --filter @sapataria/api prisma:validate",
    "prisma:generate": "pnpm --filter @sapataria/api prisma:generate"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0"
  }
}
