# =============================================================================
# Sapataria Web — Variáveis de ambiente
# Copie este arquivo para .env na raiz do projeto.
# NUNCA commite o arquivo .env real.
# =============================================================================

# ---------------------
# Banco de dados (PostgreSQL)
# ---------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=root
DATABASE_NAME=sapataria_db

# URL completa usada pelo Prisma (sem interpolação de variáveis)
DATABASE_URL=postgresql://postgres:root@localhost:5432/sapataria_db

# ---------------------
# API (NestJS)
# ---------------------
API_PORT=3001

# ---------------------
# Web (Next.js)
# ---------------------
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api
