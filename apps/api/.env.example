# =============================================================================
# apps/api — Variáveis de ambiente da API (NestJS)
# Copie este arquivo para .env dentro de apps/api/.
# NUNCA commite o arquivo .env real.
# =============================================================================

# ---------------------
# Banco de dados (PostgreSQL)
# ---------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=sapataria
DATABASE_PASSWORD=sapataria
DATABASE_NAME=sapataria_db

# URL completa usada pelo Prisma (sem interpolação de variáveis)
DATABASE_URL=postgresql://sapataria:sapataria@localhost:5432/sapataria_db

# ---------------------
# API (NestJS)
# ---------------------
API_PORT=3001
NODE_ENV=development
